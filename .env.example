# ========================================
# Prompt Generator Pro - Environment Configuration
# ========================================
# Copy this file to .env.local and fill in your values
# .env.local is NEVER committed to git
# ========================================

# ─── SUPABASE CONFIGURATION ───
# Get these from: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── BACKEND CONFIGURATION (Backend Only) ───
# These should NEVER be exposed to the frontend
# Only use in Supabase Edge Functions
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── API CONFIGURATION ───
VITE_API_URL=http://localhost:3000
VITE_API_TIMEOUT=30000

# ─── DEVELOPMENT ───
VITE_LOG_LEVEL=debug

# ─── OPTIONAL: AI SERVICE ───
# If integrating external AI service
# VITE_AI_API_KEY=your-key-here
# VITE_AI_API_URL=https://api.example.com

# ─── OPTIONAL: ANALYTICS ───
# VITE_ANALYTICS_ID=your-analytics-id

# ========================================
# IMPORTANT SECURITY NOTES:
# ========================================
# 1. NEVER commit .env.local to git
# 2. NEVER commit actual keys in any file
# 3. Use environment variables for all secrets
# 4. Rotate API keys regularly
# 5. Use different keys for each environment:
#    - Development (local testing)
#    - Staging (pre-production)
#    - Production (live environment)
# ========================================
